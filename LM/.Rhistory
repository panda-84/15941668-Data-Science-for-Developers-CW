education <- read_csv("C:/Users/Bibek/OneDrive/Documents/Clean Data/education_clean.csv")
broadband <- read_csv("C:/Users/Bibek/OneDrive/Documents/Clean Data/broadband_clean.csv")
crime <- read_csv("C:/Users/Bibek/OneDrive/Documents/Clean Data/crime_clean.csv")
population <- read_csv("C:/Users/Bibek/OneDrive/Documents/Clean Data/population_clean.csv")
glimpse(house)
