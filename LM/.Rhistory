house <- house %>%
mutate(
year = year(as.Date(transfer_date)),
town = toupper(trimws(town_city)),
county = toupper(trimws(county))
)
house_summary <- house %>%
filter(year == 2025) %>%
group_by(town, county) %>%
summarise(
avg_price = mean(price, na.rm = TRUE),
.groups = "drop"
)
print(house_summary)
education <- education %>%
mutate(
town = toupper(trimws(town)),
county = toupper(trimws(county))
) %>%
filter(
!is.na(town),
town != "",
town != "NA",
town != "NORFOLK",
town != "SUFFOLK"
)
education_summary <- education %>%
filter(year == "2024-2025") %>%
group_by(town, county) %>%
summarise(
avg_att8 = mean(att8_score, na.rm = TRUE),
.groups = "drop"
)
print(education_summary)
recommendation <- house_summary %>%
left_join(
education_summary,
by = c("town", "county")
)
print(recommendation)
table(recommendation$county)
county_speed <- broadband %>%
group_by(county) %>%
summarise(
avg_download = mean(avg_download, na.rm = TRUE),
max_download = mean(max_download, na.rm = TRUE),
.groups = "drop"
)
print(county_speed)
county_crime <- crime %>%
mutate(
year = as.numeric(substr(month, 1, 4))
) %>%
filter(year == 2025) %>%
group_by(county) %>%
summarise(
total_crimes = n(),
.groups = "drop"
) %>%
left_join(population, by = "county") %>%
mutate(
crime_rate_per_100k =
(total_crimes / total_population) * 100000
) %>%
select(
county,
total_crimes,
total_population,
crime_rate_per_100k
)
print(county_crime)
# ============================================
# Merge Everything
# ============================================
recommendation <- recommendation %>%
left_join(
county_speed,
by = "county"
) %>%
left_join(
county_crime,
by = "county"
)
# ============================================
# Remove Missing Values
# ============================================
recommendation <- recommendation %>%
filter(
!is.na(avg_att8),
!is.na(avg_download),
!is.na(crime_rate_per_100k)
)
# ============================================
# Final Dataset Check
# ============================================
glimpse(recommendation)
head(recommendation)
summary(recommendation)
table(recommendation$county)
# ============================================
# PART 2 - Calculate Recommendation Scores
# ============================================
# --------------------------------------------
# Normalization Function
# --------------------------------------------
normalize <- function(x, reverse = FALSE){
score <- (x - min(x, na.rm = TRUE)) /
(max(x, na.rm = TRUE) - min(x, na.rm = TRUE))
score <- score * 100
if(reverse){
score <- 100 - score
}
return(score)
}
# ============================================
# Calculate Individual Scores
# ============================================
recommendation <- recommendation %>%
mutate(
# Lower house price = Better
house_score =
normalize(avg_price, reverse = TRUE),
# Higher Attainment 8 = Better
school_score =
normalize(avg_att8),
# Higher broadband speed = Better
broadband_score =
normalize(avg_download),
# Lower crime rate = Better
crime_score =
normalize(crime_rate_per_100k, reverse = TRUE)
)
# ============================================
# Calculate Overall Score
# ============================================
recommendation <- recommendation %>%
mutate(
overall_score =
round(
(
house_score +
school_score +
broadband_score +
crime_score
) / 4,
1
)
)
# ============================================
# Rank Towns
# ============================================
top10 <- recommendation %>%
arrange(desc(overall_score)) %>%
select(
town,
county,
avg_price,
avg_att8,
avg_download,
crime_rate_per_100k,
overall_score
) %>%
slice(1:10)
# Display Top 10
print(top10)
# ============================================
# Save Recommendation Table
# ============================================
write_csv(
top10,
"Clean Data/top10_towns_recommendation.csv"
)
