library(readr)
library(dplyr)
library(stringr)
population_data <- read_csv(
"C:/Users/Bibek/OneDrive/Documents/Raw_data/Population2011_1656567141570.csv",
show_col_types = FALSE
)
population_clean <- population_data %>%
transmute(
postcode = Postcode,
population = as.numeric(gsub(",", "", Population)),
postcode_area = str_extract(Postcode, "^[A-Z]+")
) %>%
filter(postcode_area %in% c("NR", "IP")) %>%
mutate(
county = case_when(
postcode_area == "NR" ~ "NORFOLK",
postcode_area == "IP" ~ "SUFFOLK"
)
)
# Calculate total population by county
population_summary <- population_clean %>%
group_by(county) %>%
summarise(
total_population = sum(population, na.rm = TRUE),
.groups = "drop"
)
# Preview
print(population_summary)
# Create output folder if it doesn't exist
dir.create(
"C:/Users/Bibek/OneDrive/Documents/Raw_data/population_clean",
showWarnings = FALSE,
recursive = TRUE
)
# Save cleaned dataset
write_csv(
population_summary,
"C:/Users/Bibek/OneDrive/Documents/Raw_data/population_clean/population_clean.csv"
)
cat("Population dataset cleaned successfully!\n")
library(readr)
library(dplyr)
library(stringr)
score_paths <- list.files(
path = "Raw Data/education",
pattern = "ks4final.csv$",
recursive = TRUE,
full.names = TRUE
)
school_paths <- list.files(
path = "Raw Data/education",
pattern = "school_information.csv$",
recursive = TRUE,
full.names = TRUE
)
cat("Score Files :", length(score_paths), "\n")
cat("School Files:", length(school_paths), "\n")
score_data <- lapply(score_paths, function(file){
data <- read_csv(
file,
col_types = cols(.default = "c")
)
data %>%
transmute(
URN,
LEA,
attainment8 = suppressWarnings(as.numeric(ATT8SCR)),
academic_year = str_extract(file, "[0-9]{4}-[0-9]{4}")
)
}) %>%
bind_rows()
school_data <- lapply(school_paths, function(file){
read_csv(
file,
col_types = cols(.default = "c")
) %>%
transmute(
URN,
town = TOWN
)
}) %>%
bind_rows() %>%
distinct(URN, .keep_all = TRUE)
